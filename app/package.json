{
  "name": "surevideotool-desktop",
  "private": true,
  "version": "1.0.9",
  "description": "Surevideotool desktop app with bundled virtual camera install flow.",
  "author": "Surevideotool",
  "repository": {
    "type": "git",
    "url": "https://github.com/samuellucky2424-afk/Surevideotool-project.git"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:api": "npx kill-port 3000 && tsx server.js",
    "dev:full": "npm run dev",
    "build": "npm run build:app",
    "build:app": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc -b && vite build",
    "preview": "vite preview",
    "electron:only": "electron .",
    "electron:dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\" \"npm run electron:dev:wait\"",
    "electron:dev:wait": "wait-on tcp:127.0.0.1:3000 tcp:127.0.0.1:5173 && electron .",
    "clean:build": "node scripts/clean-build.cjs",
    "icons": "node scripts/generate-icons.cjs",
    "electron:build": "npm run icons && npm run clean:build && npm run build:app && electron-builder --win --publish never",
    "electron:build:dir": "npm run icons && npm run clean:build && npm run build:app && electron-builder --win dir",
    "electron:release": "npm run icons && npm run clean:build && npm run build:app && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.surevideotool.app",
    "productName": "Surevideotool",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": "."
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "afterPack": "build/afterPack.cjs",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "nsis": {
      "artifactName": "Surevideotool Setup ${version}.${ext}",
      "include": "build/installer.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false
    },
    "portable": {
      "artifactName": "Surevideotool ${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "samuellucky2424-afk",
        "repo": "Surevideotool-project",
        "releaseType": "release",
        "tagNamePrefix": "v"
      }
    ]
  },
  "dependencies": {
    "@decartai/sdk": "^0.0.60",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.8.3",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.18.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "multer": "^1.4.5-lts.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-resizable-panels": "^4.2.2",
    "react-router-dom": "^7.13.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^9.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "kimi-plugin-inspect-react": "^1.0.3",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^8.0.3"
  }
}
